<?xml version='1.0' standalone='yes'?>
<!DOCTYPE PLUGIN>

<PLUGIN
  name="{{ name }}"
  author="{{ author }}"
  version="{{ env['PLUGIN_VERSION'] }}"
  {% if launch is defined %}launch="{{ launch }}"{% endif %}
  pluginURL="https://raw.githubusercontent.com/{{ env['GITHUB_REPOSITORY'] }}/main/plugin/{{ name }}.plg"
  {% if support is defined %}support="{{ support }}"{% endif %}
  {% if min is defined %}min="{{ min }}"{% endif %}
  {% if max is defined %}max="{{ max }}"{% endif %}
  {% if icon is defined %}icon="{{ icon }}"{% endif %}
>

<CHANGES>
<![CDATA[
{{ env['PLUGIN_CHANGELOG'] }}

For older releases, see https://github.com/{{ env['GITHUB_REPOSITORY'] }}/releases
]]>
</CHANGES>

<FILE Name="/boot/config/plugins/{{ name }}/{{ package_name }}-{{ env['PLUGIN_VERSION'] }}-noarch-1.txz">
<URL>https://github.com/{{ env['GITHUB_REPOSITORY'] }}/releases/download/{{ env['PLUGIN_VERSION'] }}/{{ package_name }}-{{ env['PLUGIN_VERSION'] }}-noarch-1.txz</URL>
<SHA256>{{ env['PLUGIN_CHECKSUM'] }}</SHA256>
</FILE>

<!-- ==========================================================
     INSTALL / UPGRADE SCRIPT
========================================================== -->
<FILE Run="/bin/bash">
<INLINE>
<![CDATA[
# ==========================================================
#  INSTALL / UPGRADE LOGIC
# ==========================================================

PACKAGE_TXZ="/boot/config/plugins/{{ name }}/{{ package_name }}-{{ env['PLUGIN_VERSION'] }}-noarch-1.txz"

# Config paths
FLASH_CFG="/boot/config/plugins/{{ name }}/flash-backup/flash-backup.cfg"
VM_CFG="/boot/config/plugins/{{ name }}/vm-backup-and-restore/vm-backup.cfg"
WHICH_CFG="/boot/config/plugins/{{ name }}/which-plugin.cfg"

# Default config sources (shipped inside the package)
FLASH_DEFAULT_CFG="/usr/local/emhttp/plugins/{{ name }}/helpers/default_flash.cfg"
VM_DEFAULT_CFG="/usr/local/emhttp/plugins/{{ name }}/helpers/default_vm.cfg"

# Temp files for ordered rebuild
TMP_FLASH="/tmp/{{ name }}_flash.tmp"
TMP_VM="/tmp/{{ name }}_vm.tmp"

# Install (or upgrade) the package
upgradepkg --install-new "$PACKAGE_TXZ"

# ==========================================================
#  WHICH-PLUGIN CONFIG
#  Only created on first install; never overwritten on upgrade
# ==========================================================
if [ ! -f "$WHICH_CFG" ]; then
    echo "SELECTED_TOOL=flash-local" > "$WHICH_CFG"
fi

# ==========================================================
#  FLASH BACKUP CONFIG
# ==========================================================
ordered_flash_keys=(
    "FLASH_LOCAL_DEST"
    "FLASH_LOCAL_RETENTION"
    "FLASH_LOCAL_COMPRESS"
    "FLASH_LOCAL_INCLUDE"
    "FLASH_LOCAL_EXCLUDE"
    "FLASH_LOCAL_DRY_RUN"
    "FLASH_LOCAL_DISCORD"
    "FLASH_REMOTE_HOST"
    "FLASH_REMOTE_USER"
    "FLASH_REMOTE_KEY"
    "FLASH_REMOTE_DEST"
    "FLASH_REMOTE_BW_LIMIT"
    "FLASH_REMOTE_RETENTION"
    "FLASH_REMOTE_DRY_RUN"
)

mkdir -p "$(dirname "$FLASH_CFG")"

if [ ! -f "$FLASH_CFG" ]; then
    cp "$FLASH_DEFAULT_CFG" "$FLASH_CFG"
else
    # Merge: add any keys present in defaults but missing from user config
    while IFS='=' read -r key val; do
        [[ -z "$key" || "$key" =~ ^[[:space:]]*# ]] && continue
        if ! grep -q -E "^[[:space:]]*${key}[[:space:]]*=" "$FLASH_CFG"; then
            echo "$key=$val" >> "$FLASH_CFG"
        fi
    done < "$FLASH_DEFAULT_CFG"
fi

# Rebuild in canonical key order (drops any unrecognised keys)
{
    for key in "${ordered_flash_keys[@]}"; do
        grep -E "^[[:space:]]*${key}[[:space:]]*=" "$FLASH_CFG" || true
    done
} > "$TMP_FLASH"

mv "$TMP_FLASH" "$FLASH_CFG"

# ==========================================================
#  VM BACKUP CONFIG
# ==========================================================
ordered_vm_keys=(
    "VM_BACKUP_VMS"
    "VM_BACKUP_DEST"
    "VM_BACKUP_MODE"
    "VM_BACKUP_COMPRESS"
    "VM_BACKUP_RETENTION"
    "VM_BACKUP_INCLUDE_LIBVIRT"
    "VM_BACKUP_AUTOSTART"
    "VM_BACKUP_DRY_RUN"
    "VM_RESTORE_FILE"
    "VM_RESTORE_TARGET"
    "VM_RESTORE_OVERWRITE"
    "VM_RESTORE_DISKS"
    "VM_RESTORE_CONFIG"
    "VM_RESTORE_DRY_RUN"
)

mkdir -p "$(dirname "$VM_CFG")"

if [ ! -f "$VM_CFG" ]; then
    cp "$VM_DEFAULT_CFG" "$VM_CFG"
else
    while IFS='=' read -r key val; do
        [[ -z "$key" || "$key" =~ ^[[:space:]]*# ]] && continue
        if ! grep -q -E "^[[:space:]]*${key}[[:space:]]*=" "$VM_CFG"; then
            echo "$key=$val" >> "$VM_CFG"
        fi
    done < "$VM_DEFAULT_CFG"
fi

{
    for key in "${ordered_vm_keys[@]}"; do
        grep -E "^[[:space:]]*${key}[[:space:]]*=" "$VM_CFG" || true
    done
} > "$TMP_VM"

mv "$TMP_VM" "$VM_CFG"

# ==========================================================
#  LOG DIRECTORY
# ==========================================================
mkdir -p /boot/logs/{{ name }}

# ==========================================================
#  SCRIPT PERMISSIONS
# ==========================================================
chmod +x /usr/local/emhttp/plugins/{{ name }}/scripts/backup.sh 2>/dev/null || true
chmod +x /usr/local/emhttp/plugins/{{ name }}/scripts/stop.sh   2>/dev/null || true

# ==========================================================
#  CLEANUP OLD PACKAGES
#  Keep only the current txz; remove previous versions
# ==========================================================
find /boot/config/plugins/{{ name }}/ -maxdepth 1 -type f \
    -name "{{ package_name }}-*.txz" \
    ! -name "{{ package_name }}-{{ env['PLUGIN_VERSION'] }}-noarch-1.txz" \
    -delete

echo ""
echo "----------------------------------------------------"
echo " {{ name }} has been installed."
echo " Version : {{ env['PLUGIN_VERSION'] }}"
echo " Flash   : $FLASH_CFG"
echo " VM      : $VM_CFG"
echo "----------------------------------------------------"
echo ""

]]>
</INLINE>
</FILE>

<!-- ==========================================================
     REMOVE SCRIPT
========================================================== -->
<FILE Run="/bin/bash" Method="remove">
<INLINE>
<![CDATA[
# Stop any running backup cleanly before removal
if [ -f /tmp/{{ name }}.lock ]; then
    touch /tmp/{{ name }}.stop
    sleep 3
fi

# Remove lock/stop artifacts
rm -f /tmp/{{ name }}.lock
rm -f /tmp/{{ name }}.stop

# Remove the installed package and UI files
removepkg {{ package_name }}
rm -rf /usr/local/emhttp/plugins/{{ name }}

# NOTE: config and logs are intentionally preserved on removal
# /boot/config/plugins/{{ name }}/   — user settings preserved
# /boot/logs/{{ name }}/             — logs preserved
]]>
</INLINE>
</FILE>

</PLUGIN>
