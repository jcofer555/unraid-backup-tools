// Helper: checked/selected
function ubt_bool(string $val): bool { return $val === 'yes'; }
function ubt_checked(bool $val): string { return $val ? ' checked' : ''; }
function ubt_opt(string $val, string $cmp): string { return $val === $cmp ? ' selected' : ''; }
