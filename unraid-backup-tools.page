          <!-- Auto-start after backup -->
          <div class="ubt-field ubt-field--toggle">
            <label>Auto-start After Backup</label>
            <label class="ubt-switch">
              <input type="checkbox" name="vm_backup_autostart" value="yes"
                     <?= ubt_checked(ubt_bool($v['VM_BACKUP_AUTOSTART'])) ?>>
              <span class="ubt-slider"></span>
            </label>
            <span class="ubt-hint">Restart VM once backup completes (only for stop mode).</span>
          </div>

          <!-- Dry Run -->
          <div class="ubt-field ubt-field--toggle">
            <label>Dry Run</label>
            <label class="ubt-switch">
              <input type="checkbox" name="vm_backup_dry_run" value="yes"
                     <?= ubt_checked(ubt_bool($v['VM_BACKUP_DRY_RUN'])) ?>>
              <span class="ubt-slider"></span>
            </label>
          </div>

        </div><!-- /.ubt-fields -->

        <div class="ubt-actions">
          <button type="submit" class="ubt-btn ubt-btn--save">Save Settings</button>
          <button type="button" class="ubt-btn ubt-btn--run" id="run-vm-backup"
                  data-mode="vm-backup" <?= $running ? 'disabled' : '' ?>>
            Run Now
          </button>
          <button type="button" class="ubt-btn ubt-btn--stop"
                  <?= !$running ? 'disabled' : '' ?>>Stop</button>
        </div>
      </form>
    </div>
  </section>

  <!-- ============================================================
       PANEL: VM Restore
       ============================================================ -->
  <section class="ubt-panel" id="panel-vm-restore" data-panel="vm-restore">
    <div class="ubt-card">
      <div class="ubt-card-header">
        <span class="ubt-card-icon">&#9850;</span>
        <h2>VM Restore</h2>
        <span class="ubt-card-desc">Restore a virtual machine from a backup archive.</span>
      </div>
      <form id="form-vm-restore" method="post" action="">
        <input type="hidden" name="ubt_action" value="save_vm">

        <div class="ubt-fields">

          <!-- Backup file -->
          <div class="ubt-field">
            <label for="vm_restore_file">Backup Archive Path</label>
            <input type="text" id="vm_restore_file" name="vm_restore_file"
                   placeholder="/mnt/user/backups/vms/myvm_2025-01-01.tar.gz"
                   value="<?= htmlspecialchars($v['VM_RESTORE_FILE']) ?>">
            <span class="ubt-hint">Full path to the .tar.gz backup created by VM Backup.</span>
          </div>

          <!-- Target VM name -->
          <div class="ubt-field ubt-field--half">
            <label for="vm_restore_target">Target VM Name</label>
            <input type="text" id="vm_restore_target" name="vm_restore_target"
                   placeholder="myvm"
                   value="<?= htmlspecialchars($v['VM_RESTORE_TARGET']) ?>">
            <span class="ubt-hint">Leave blank to use name from archive.</span>
          </div>

          <!-- Overwrite -->
          <div class="ubt-field ubt-field--toggle">
            <label>Overwrite Existing VM</label>
            <label class="ubt-switch">
              <input type="checkbox" name="vm_restore_overwrite" value="yes"
                     id="restore-overwrite"
                     <?= ubt_checked(ubt_bool($v['VM_RESTORE_OVERWRITE'])) ?>>
              <span class="ubt-slider"></span>
            </label>
            <span class="ubt-hint ubt-hint--warn">Destructive — existing VM data will be removed.</span>
          </div>

          <!-- Restore disks -->
          <div class="ubt-field ubt-field--toggle">
            <label>Restore Disk Images</label>
            <label class="ubt-switch">
              <input type="checkbox" name="vm_restore_disks" value="yes"
                     <?= ubt_checked(ubt_bool($v['VM_RESTORE_DISKS'])) ?>>
              <span class="ubt-slider"></span>
            </label>
          </div>

          <!-- Restore config -->
          <div class="ubt-field ubt-field--toggle">
            <label>Restore libvirt XML Config</label>
            <label class="ubt-switch">
              <input type="checkbox" name="vm_restore_config" value="yes"
                     <?= ubt_checked(ubt_bool($v['VM_RESTORE_CONFIG'])) ?>>
              <span class="ubt-slider"></span>
            </label>
          </div>

          <!-- Dry Run -->
          <div class="ubt-field ubt-field--toggle">
            <label>Dry Run</label>
            <label class="ubt-switch">
              <input type="checkbox" name="vm_restore_dry_run" value="yes"
                     <?= ubt_checked(ubt_bool($v['VM_RESTORE_DRY_RUN'])) ?>>
              <span class="ubt-slider"></span>
            </label>
          </div>

        </div><!-- /.ubt-fields -->

        <div class="ubt-actions">
          <button type="submit" class="ubt-btn ubt-btn--save">Save Settings</button>
          <button type="button" class="ubt-btn ubt-btn--run ubt-btn--danger"
                  id="run-vm-restore" data-mode="vm-restore"
                  <?= $running ? 'disabled' : '' ?>>
            Restore Now
          </button>
          <button type="button" class="ubt-btn ubt-btn--stop"
                  <?= !$running ? 'disabled' : '' ?>>Stop</button>
        </div>
      </form>
    </div>
  </section>

  <!-- ============================================================
       LOG VIEWER
       ============================================================ -->
  <div class="ubt-card ubt-log-card" id="ubt-log-card">
    <div class="ubt-log-header">
      <h3>&#128196; Log Output</h3>
      <div class="ubt-log-controls">
        <select id="ubt-log-file-select">
          <option value="live">— Live stream —</option>
        </select>
        <button type="button" class="ubt-btn ubt-btn--sm" id="ubt-log-refresh">Refresh</button>
        <button type="button" class="ubt-btn ubt-btn--sm" id="ubt-log-clear">Clear View</button>
      </div>
    </div>
    <pre class="ubt-log-area" id="ubt-log-area">Idle — run a backup to see output here.</pre>
  </div>

</div><!-- /.ubt-main -->

<!-- ============================================================
     CONFIRMATION MODAL (VM Restore)
     ============================================================ -->
<div class="ubt-modal-overlay" id="ubt-confirm-modal" aria-hidden="true">
  <div class="ubt-modal" role="dialog" aria-modal="true" aria-labelledby="modal-title">
    <h2 id="modal-title">&#9888; Confirm VM Restore</h2>
    <p class="ubt-modal-body" id="modal-body">
      This will overwrite the existing VM. All current disk data will be lost.
      Are you sure you want to continue?
    </p>
    <div class="ubt-modal-actions">
      <button class="ubt-btn ubt-btn--danger" id="modal-confirm">Yes, Restore</button>
      <button class="ubt-btn ubt-btn--save"   id="modal-cancel">Cancel</button>
    </div>
  </div>
</div>

<script src="<?= UBT_ASSET_BASE ?>/js/app.js"></script>
