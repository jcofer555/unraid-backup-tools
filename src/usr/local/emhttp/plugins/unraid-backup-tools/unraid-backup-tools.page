function ubt_parse_cfg(string $path): array {
    if (!file_exists($path)) return [];
    $cfg = [];
    foreach (file($path, FILE_IGNORE_NEW_LINES | FILE_SKIP_EMPTY_LINES) as $line) {
        $line = trim($line);
        if ($line === '' || $line[0] === '#') continue;
        $parts = explode('=', $line, 2);
        if (count($parts) === 2) $cfg[trim($parts[0])] = trim($parts[1]);
    }
    return $cfg;
}

function ubt_write_cfg(string $path, array $data): bool {
    $dir = dirname($path);
    if (!is_dir($dir)) mkdir($dir, 0755, true);
    ksort($data);
    $lines = [];
    foreach ($data as $k => $v) $lines[] = $k . '=' . $v;
    return file_put_contents($path, implode("\n", $lines) . "\n", LOCK_EX) !== false;
}

function ubt_sanitize(string $val, string $type = 'text'): string {
    $val = trim($val);
    switch ($type) {
        case 'path': return preg_replace('/[^a-zA-Z0-9\/\-_. ]/', '', $val);
        case 'host': return preg_replace('/[^a-zA-Z0-9.\-]/', '', $val);
        case 'user': return preg_replace('/[^a-zA-Z0-9_\-.]/', '', $val);
        case 'int':  return (string)(int)$val;
        case 'bool': return in_array(strtolower($val), ['yes','true','1'], true) ? 'yes' : 'no';
        default:     return preg_replace('/[`$;|&<>!]/', '', $val);
    }
}

function ubt_running_mode(): string {
    if (!file_exists(UBT_LOCK)) return '';
    return trim(file_get_contents(UBT_LOCK)) ?: 'unknown';
}

function ubt_list_vms(): array {
    $output = [];
    exec('virsh list --all --name 2>/dev/null', $output);
    return array_filter(array_map('trim', $output), fn($v) => $v !== '');
}

$page_message = '';
$page_error   = '';

if ($_SERVER['REQUEST_METHOD'] === 'POST') {
    $action = $_POST['ubt_action'] ?? '';

    if ($action === 'save_flash') {
        $cfg = ubt_parse_cfg(UBT_FLASH_CFG);
        $cfg['FLASH_LOCAL_DEST']       = ubt_sanitize($_POST['flash_local_dest']       ?? '', 'path');
        $cfg['FLASH_LOCAL_RETENTION']  = ubt_sanitize($_POST['flash_local_retention']  ?? '5', 'int');
        $cfg['FLASH_LOCAL_COMPRESS']   = ubt_sanitize($_POST['flash_local_compress']   ?? 'no', 'bool');
        $cfg['FLASH_LOCAL_INCLUDE']    = ubt_sanitize($_POST['flash_local_include']    ?? '', 'path');
        $cfg['FLASH_LOCAL_EXCLUDE']    = ubt_sanitize($_POST['flash_local_exclude']    ?? '', 'path');
        $cfg['FLASH_LOCAL_DRY_RUN']    = ubt_sanitize($_POST['flash_local_dry_run']    ?? 'no', 'bool');
        $cfg['FLASH_LOCAL_DISCORD']    = ubt_sanitize($_POST['flash_local_discord']    ?? '');
        $cfg['FLASH_REMOTE_HOST']      = ubt_sanitize($_POST['flash_remote_host']      ?? '', 'host');
        $cfg['FLASH_REMOTE_USER']      = ubt_sanitize($_POST['flash_remote_user']      ?? '', 'user');
        $cfg['FLASH_REMOTE_KEY']       = ubt_sanitize($_POST['flash_remote_key']       ?? '', 'path');
        $cfg['FLASH_REMOTE_DEST']      = ubt_sanitize($_POST['flash_remote_dest']      ?? '', 'path');
        $cfg['FLASH_REMOTE_BW_LIMIT']  = ubt_sanitize($_POST['flash_remote_bw_limit']  ?? '0', 'int');
        $cfg['FLASH_REMOTE_RETENTION'] = ubt_sanitize($_POST['flash_remote_retention'] ?? '5', 'int');
        $cfg['FLASH_REMOTE_DRY_RUN']   = ubt_sanitize($_POST['flash_remote_dry_run']   ?? 'no', 'bool');
        ubt_write_cfg(UBT_FLASH_CFG, $cfg) ? $page_message = 'Flash settings saved.' : $page_error = 'Failed to save flash-backup.cfg';
    }

    elseif ($action === 'save_vm') {
        $cfg = ubt_parse_cfg(UBT_VM_CFG);
        $cfg['VM_BACKUP_VMS']             = ubt_sanitize(implode(',', $_POST['vm_backup_vms'] ?? []), 'text');
        $cfg['VM_BACKUP_DEST']            = ubt_sanitize($_POST['vm_backup_dest']            ?? '', 'path');
        $cfg['VM_BACKUP_MODE']            = in_array($_POST['vm_backup_mode'] ?? '', ['stop','snapshot','live']) ? $_POST['vm_backup_mode'] : 'stop';
        $cfg['VM_BACKUP_COMPRESS']        = ubt_sanitize($_POST['vm_backup_compress']        ?? 'no', 'bool');
        $cfg['VM_BACKUP_RETENTION']       = ubt_sanitize($_POST['vm_backup_retention']       ?? '5', 'int');
        $cfg['VM_BACKUP_INCLUDE_LIBVIRT'] = ubt_sanitize($_POST['vm_backup_include_libvirt'] ?? 'yes', 'bool');
        $cfg['VM_BACKUP_AUTOSTART']       = ubt_sanitize($_POST['vm_backup_autostart']       ?? 'no', 'bool');
        $cfg['VM_BACKUP_DRY_RUN']         = ubt_sanitize($_POST['vm_backup_dry_run']         ?? 'no', 'bool');
        $cfg['VM_RESTORE_FILE']           = ubt_sanitize($_POST['vm_restore_file']           ?? '', 'path');
        $cfg['VM_RESTORE_TARGET']         = ubt_sanitize($_POST['vm_restore_target']         ?? '', 'text');
        $cfg['VM_RESTORE_OVERWRITE']      = ubt_sanitize($_POST['vm_restore_overwrite']      ?? 'no', 'bool');
        $cfg['VM_RESTORE_DISKS']          = ubt_sanitize($_POST['vm_restore_disks']          ?? 'yes', 'bool');
        $cfg['VM_RESTORE_CONFIG']         = ubt_sanitize($_POST['vm_restore_config']         ?? 'yes', 'bool');
        $cfg['VM_RESTORE_DRY_RUN']        = ubt_sanitize($_POST['vm_restore_dry_run']        ?? 'no', 'bool');
        ubt_write_cfg(UBT_VM_CFG, $cfg) ? $page_message = 'VM settings saved.' : $page_error = 'Failed to save vm-backup.cfg';
    }
}

