     Active Plugin Panel — renders selected plugin content
============================================================ -->
<div id="jcp-plugin-panel">
<?php
// Deterministic conditional include — only selected plugin content is rendered
// This avoids DOM/JS collisions between the two plugins.
$pluginPageMap = [
    'flash-backup'           => __DIR__ . '/flash-backup/flash-backup-content.php',
    'vm-backup-and-restore'  => __DIR__ . '/vm-backup-and-restore/vm-backup-and-restore-content.php',
];

$contentFile = $pluginPageMap[$selectedPlugin] ?? null;
if ($contentFile && file_exists($contentFile)) {
    include $contentFile;
} else {
    echo '<p style="color:red;">Plugin content not found: ' . htmlspecialchars($selectedPlugin) . '</p>';
}
?>
</div>

<script>
(function () {
  'use strict';

  // ============================================================
  // JCP Plugin Selector — explicit state machine
  // States: IDLE → SAVING → RELOADING
  // ============================================================

  /** @type {'IDLE'|'SAVING'|'RELOADING'} */
  var STATE = 'IDLE';

  var select  = document.getElementById('jcp-plugin-select');
  var saveBtn = document.getElementById('jcp-save-plugin-btn');
  var toast   = document.getElementById('jcp-switch-toast');

  function setState(s) {
    STATE = s;
    if (s === 'IDLE') {
      saveBtn.disabled = false;
      toast.style.display = 'none';
    } else if (s === 'SAVING') {
      saveBtn.disabled = true;
      toast.textContent = 'Switching…';
      toast.style.display = 'inline-block';
    } else if (s === 'RELOADING') {
      saveBtn.disabled = true;
      toast.textContent = 'Reloading page…';
      toast.style.display = 'inline-block';
    }
  }

  saveBtn.addEventListener('click', function () {
    if (STATE !== 'IDLE') return; // guard against re-entry
    var plugin = select.value;
    setState('SAVING');

    var xhr = new XMLHttpRequest();
    xhr.open('POST', '/plugins/unraid-backup-tools/helpers/save_which_plugin.php', true);
    xhr.setRequestHeader('Content-Type', 'application/x-www-form-urlencoded');
    xhr.timeout = 8000;

    xhr.onload = function () {
      try {
        var res = JSON.parse(xhr.responseText);
        if (res.status === 'ok') {
          setState('RELOADING');
          window.location.reload();
        } else {
          setState('IDLE');
          alert('Failed to save plugin selection: ' + (res.message || 'Unknown error'));
        }
      } catch (e) {
        setState('IDLE');
        alert('Unexpected response from server');
      }
    };

    xhr.onerror = xhr.ontimeout = function () {
      setState('IDLE');
      alert('Network error saving plugin selection');
    };

    xhr.send('plugin=' + encodeURIComponent(plugin));
  });

  setState('IDLE');
})();
</script>
