<?php
// ============================================================
// Unraid Backup Tools — Plugin Selector
// Deterministic, auditable, atomic per unified-jonathan-weighted-skill
// ============================================================

$jcpCfgDir  = '/boot/config/plugins/unraid-backup-tools';
$whichCfg   = $jcpCfgDir . '/which-plugin.cfg';
$allowedPlugins = ['flash-backup', 'vm-backup-and-restore'];

// Read saved plugin selection — deterministic default to flash-backup
$selectedPlugin = 'flash-backup';
if (file_exists($whichCfg)) {
    $parsed = parse_ini_file($whichCfg);
    if (!empty($parsed['WHICH_PLUGIN']) && in_array($parsed['WHICH_PLUGIN'], $allowedPlugins, true)) {
        $selectedPlugin = $parsed['WHICH_PLUGIN'];
    }
}
